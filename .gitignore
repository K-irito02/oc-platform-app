# ============================================================
# OC Platform Git 忽略配置
# ============================================================
#
# 【部署时需要手动提供的文件】
# 以下文件被 Git 忽略，部署时需要手动创建或提供：
#
# 1. 环境配置文件：
#    - .env                          # Docker Compose 环境变量（数据库密码等）
#    - application-dev.yml           # Spring Boot 开发环境配置
#    - application-prod.yml          # Spring Boot 生产环境配置
#    - oc-platform-web/.env.local    # 前端本地环境变量
#    - oc-platform-web/.env.production # 前端生产环境变量
#
# 2. 敏感配置（已在 init.sql 中配置，但建议生产环境单独管理）：
#    - Cloudflare Turnstile 密钥（captcha.cloudflare.site_key/secret_key）
#    - JWT 密钥
#    - 邮件服务配置（SMTP 密码）
#    - OAuth 客户端密钥
#
# 3. 数据目录（生产环境需挂载持久化卷）：
#    - data/                         # PostgreSQL 数据
#    - pgdata/                       # PostgreSQL 数据目录
#    - redis-data/                   # Redis 数据
#    - uploads/                      # 用户上传文件
#    - files/                        # 文件存储
#
# 4. SSL 证书（如需 HTTPS）：
#    - ssl/cert.pem
#    - ssl/key.pem
#
# ============================================================

# ===== Java / Maven =====
target/
*.class
*.jar
*.war
*.ear
*.log
*.iml
*.ipr
*.iws

# ===== Spring Boot =====
# 【部署需提供】application-dev.yml, application-prod.yml
application-*.yml
application-*.properties
!application.yml
!application.properties

# ===== IDE =====
.idea/
.vscode/
.settings/
.project
.classpath
.factorypath
.springBeans
.sts4-cache/

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ===== Environment =====
# 【部署需提供】.env 文件包含数据库密码、JWT密钥等敏感信息
.env
*.env.local
*.env.production
.env.development
.env.test

# ===== Node.js (前端) =====
oc-platform-web/node_modules/
oc-platform-web/dist/
# 【部署需提供】前端环境变量（API地址等）
oc-platform-web/.env.local
oc-platform-web/.env.production
oc-platform-web/.env.development
oc-platform-web/.env.test
oc-platform-web/npm-debug.log*
oc-platform-web/yarn-debug.log*
oc-platform-web/yarn-error.log*
oc-platform-web/lerna-debug.log*
oc-platform-web/.pnpm-debug.log*
oc-platform-web/.yarn-integrity

# ===== 前端构建产物 =====
oc-platform-web/coverage/
oc-platform-web/.nyc_output/
oc-platform-web/.cache/
oc-platform-web/.temp/
oc-platform-web/.vite/

# ===== Docker =====
docker-compose.override.yml
.dockerignore

# ===== Logs =====
logs/
*.log
nohup.out
backend*.log

# ===== 上传文件 =====
# 【部署需提供】生产环境需配置持久化存储
uploads/
files/
static/
temp/

# ===== 数据库 =====
*.db
*.sqlite
*.sqlite3

# ===== 测试 =====
.mvn/test-results/
test-results/
*.lcov
coverage/

