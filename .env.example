# .env.example（复制为 .env 并填写实际值，加入 .gitignore）
# 生产环境部署时，所有密码和密钥必须替换为强随机值！

# ===== 数据库 =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oc_platform
DB_USER=oc_user
DB_PASSWORD=CHANGE_ME_use_strong_password

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_use_strong_password

# ===== JWT =====
JWT_SECRET=CHANGE_ME_must_be_at_least_64_characters_long_for_hmac_sha256_security
JWT_ACCESS_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=604800000

# ===== OAuth - GitHub =====
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-domain.com/oauth/github/callback

# ===== 邮件 =====
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# ===== MinIO 对象存储 =====
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_use_strong_password
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_PRODUCTS=products
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_DOWNLOADS=downloads

# ===== 文件存储 =====
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=1073741824

# ===== 腾讯云验证码 =====
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET=

# ===== Docker Compose 端口 =====
BACKEND_PORT=8081
FRONTEND_PORT=80
